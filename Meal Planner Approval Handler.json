    {
      "parameters": {
        "jsCode": "const proposals = $input.all().map(i => i.json).filter(p => p.id);\n\n// Only consider proposals from the most recent week_of\nconst weeks = [...new Set(proposals.map(p => p.week_of))].sort().reverse();\nconst latestWeek = weeks[0];\nconst current = latestWeek\n  ? proposals.filter(p => p.week_of === latestWeek)\n  : [];\n\nconst active = current.filter(p => ['pending', 'approved'].includes(p.status));\nconst chatId = $('Parse Callback').first().json.chatId;\n\nif (active.length > 0) {\n  const pendingCount = active.filter(p => p.status === 'pending').length;\n  const approvedCount = active.filter(p => p.status === 'approved').length;\n  let msg = '\\ud83d\\udccb Meals already proposed for this week.';\n  if (approvedCount > 0) msg += ` ${approvedCount} approved.`;\n  if (pendingCount > 0) msg += ` ${pendingCount} still pending.`;\n  return [{ json: { text: msg, chat_id: chatId, trigger: false } }];\n}\n\nreturn [{ json: { text: '\\ud83c\\udf73 Generating meal proposals...', chat_id: chatId, trigger: true } }];"
      },
