    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\n// Check for /planmeals bot command\nif (body.message?.text?.startsWith('/planmeals')) {\n  return [{ json: { type: 'planmeals', chatId: body.message.chat.id, skip: true } }];\n}\n\nif (!body.callback_query) {\n  return [{ json: { type: 'unknown', skip: true } }];\n}\n\nconst callbackQuery = body.callback_query;\nconst data = callbackQuery.data;\nconst username = callbackQuery.from?.username || callbackQuery.from?.first_name || 'Unknown';\nconst callbackQueryId = callbackQuery.id;\nconst chatId = callbackQuery.message?.chat?.id;\nconst messageId = callbackQuery.message?.message_id;\n\nconst [decision, proposalId] = data.split(':');\n\nif (!proposalId || !['approve', 'deny'].includes(decision)) {\n  return [{ json: { type: 'unknown', skip: true } }];\n}\n\nlet displayName = username;\ntry {\n  const userMap = JSON.parse($env.TG_USER_MAP || '{}');\n  displayName = userMap[username] || username;\n} catch(e) {}\n\nreturn [{ json: { type: 'callback', decision, proposalId, username, displayName, callbackQueryId, chatId, messageId, skip: false } }];"
      },
