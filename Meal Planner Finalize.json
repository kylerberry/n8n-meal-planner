    {
      "parameters": {
        "promptType": "define",
        "text": "=Generate a complete recipe for this family meal.\n\nTitle: {{ $json.title }}\nDescription: {{ $json.description }}\nCuisine: {{ $json.cuisine }}\nProtein: {{ $json.protein }}\nEstimated active time: {{ $json.active_time_min }} minutes\nKey ingredients already in the plan: {{ JSON.stringify($json.key_ingredients) }}\nFamily notes: {{ $('Get Family Profile').first().json.portion_notes }}\n\nRequirements:\n- Serves 3 (leftovers welcome)\n- ≤45 min active time\n- Numbered steps with timing per step (e.g. \"Step 1 (5 min): ...\")\n- Complete ingredient list with every item — exact qty, unit, and section\n- Sections must be one of: produce | protein | dairy | pantry | frozen | spice\n- Note anything that can be prepped ahead of time\n\nNutrition per serving is already known — do NOT include or estimate it.\n\nReturn strict JSON only, no markdown:",
        "hasOutputParser": true
      },
      "id": "wf3-llm-chain",
      "name": "Generate Full Recipe",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.4,
      "position": [
        224,
        528
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "model": {
          "__rl": true,
          "value": "claude-haiku-4-5-20251001",
          "mode": "list",
          "cachedResultName": "Claude Haiku 4.5"
        },
        "options": {
          "temperature": 0.3
        }
      },
      "id": "wf3-anthropic",
      "name": "Anthropic Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatAnthropic",
      "typeVersion": 1.3,
      "position": [
        176,
        736
      ],
      "credentials": {
        "anthropicApi": {
