    {
      "parameters": {
        "jsonSchemaExample": "{\n  \"ingredients\": [\n    {\"name\": \"chicken breast\", \"qty\": 1.5, \"unit\": \"lb\", \"section\": \"protein\"},\n    {\"name\": \"bell pepper\", \"qty\": 3, \"unit\": \"whole\", \"section\": \"produce\"}\n  ],\n  \"steps\": [\n    \"Step 1 (5 min): Preheat oven to 425°F and line a baking sheet.\",\n    \"Step 2 (10 min): Slice chicken and vegetables into strips.\"\n  ],\n  \"prep_ahead_notes\": \"Slice and marinate chicken up to 24 hours ahead.\"\n}",
        "autoFix": true
      },
      "id": "wf3-parser",
      "name": "Recipe Output Parser",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.3,
      "position": [
        288,
        736
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const proposal = $('Get Approved Proposals').item.json;\nconst fullRecipe = $input.item.json.output;\n\nif (!fullRecipe?.ingredients || !fullRecipe?.steps) {\n  throw new Error(`Full recipe missing for \"${proposal.title}\". Got: ${JSON.stringify($input.item.json).substring(0, 200)}`);\n}\n\nreturn { ...proposal, full_recipe: fullRecipe };"
      },
      "id": "wf3-merge",
      "name": "Merge Recipe Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        624,
        528
      ]
    },
    {
      "parameters": {
        "operation": "update",
        "tableId": "proposals",
        "matchType": "allFilters",
        "filters": {
          "conditions": [
            {
              "keyName": "id",
              "condition": "eq",
              "keyValue": "={{ $json.id }}"
            }
          ]
        },
        "fieldsUi": {
          "fieldValues": [
            {
              "fieldId": "full_recipe",
              "fieldValue": "={{ JSON.stringify($json.full_recipe) }}"
            }
          ]
        }
      },
      "id": "wf3-update",
      "name": "Update Proposals",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        848,
        528
      ],
      "credentials": {
        "supabaseApi": {
          "id": "YOUR_SUPABASE_CREDENTIAL_ID",
          "name": "Supabase account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all().map(i => i.json);\n\n// Re-fetch full data from Merge Recipe Data since Update Proposals output is the DB response\nconst allRecipes = $('Merge Recipe Data').all().map(i => i.json);\n\n// Only keep recipes from the most recent week_of to avoid cross-week overlap\nconst weeks = [...new Set(allRecipes.map(r => r.week_of))].sort().reverse();\nconst latestWeek = weeks[0];\nconst recipes = allRecipes.filter(r => r.week_of === latestWeek);\n\n// Unit normalization map\nconst UNIT_NORMALIZE = {\n  lbs: 'lb', tbsps: 'tbsp', tsps: 'tsp',\n  cups: 'cup', ozs: 'oz', cloves: 'clove',\n  cans: 'can', slices: 'slice', pieces: 'piece',\n  whole: '', wholes: '',\n};\nfunction normalizeUnit(u) {\n  const lower = (u || '').toLowerCase().trim();\n  return UNIT_NORMALIZE[lower] ?? lower;\n}\n\nconst merged = {};\nconst VALID_SECTIONS = ['produce','protein','dairy','pantry','frozen','spice'];\n\nfor (const recipe of recipes) {\n  for (const ing of (recipe.full_recipe?.ingredients || [])) {\n    const normUnit = normalizeUnit(ing.unit);\n    const key = `${ing.name.toLowerCase().trim()}|${normUnit}`;\n    if (!merged[key]) {\n      merged[key] = {\n        name: ing.name,\n        qty: 0,\n        unit: normUnit,\n        section: VALID_SECTIONS.includes(ing.section) ? ing.section : 'pantry',\n        used_in: []\n      };\n    }\n    merged[key].qty += Number(ing.qty) || 0;\n    merged[key].used_in.push(recipe.title);\n  }\n}\n\nconst bySection = {};\nfor (const item of Object.values(merged)) {\n  (bySection[item.section] ||= []).push(item);\n}\n\nreturn [{ json: { recipes, grocery_list: bySection } }];"
      },
      "id": "wf3-consolidate",
      "name": "Consolidate Grocery List",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1072,
        528
      ]
    },
    {
      "parameters": {
        "jsCode": "const recipes = $('Consolidate Grocery List').first().json.recipes;\nconst dedupedItems = $input.first().json.output.items;\n\nconst SECTION_EMOJI = {\n  produce: '🥦', protein: '🥩', dairy: '🧀',\n  pantry: '🥫', frozen: '🧊', spice: '🧂'\n};\n\nconst messages = [];\n\n// One message per meal with full details\nfor (let i = 0; i < recipes.length; i++) {\n  const r = recipes[i];\n  const n = r.nutrition;\n\n  let text = `🍽️ *${i + 1}. ${r.title}*\\n`;\n\n  if (r.source_url) {\n    text += `${r.source_url}\\n`;\n  }\n\n  text += `\\n${r.description}`;\n\n  if (n) {\n    text += `\\n\\n_Per serving: ${n.calories} cal · ${n.protein_g}g protein · ${n.carbs_g}g carbs · ${n.fat_g}g fat_`;\n  }\n\n  if (r.full_recipe?.steps?.length) {\n    text += '\\n\\n*Instructions:*';\n    for (const step of r.full_recipe.steps) {\n      text += `\\n${step}`;\n    }\n  }\n\n  if (r.full_recipe?.prep_ahead_notes) {\n    text += `\\n\\n💡 *Prep ahead:* ${r.full_recipe.prep_ahead_notes}`;\n  }\n\n  messages.push({ json: { text, chat_id: $env.TELEGRAM_CHAT_ID } });\n}\n\n// Regroup deduped items by section\nconst bySection = {};\nfor (const item of dedupedItems) {\n  (bySection[item.section] ||= []).push(item);\n}\n\n// Consolidated grocery list as final message\nconst groceryLines = ['produce','protein','dairy','pantry','frozen','spice']\n  .filter(s => bySection[s]?.length)\n  .map(s => {\n    const items = bySection[s]\n      .map(item => {\n        const qty = item.qty % 1 === 0 ? item.qty : parseFloat(item.qty.toFixed(1));\n        return `  • ${qty} ${item.unit} ${item.name}`.trim();\n      })\n      .join('\\n');\n    return `${SECTION_EMOJI[s]} *${s.charAt(0).toUpperCase() + s.slice(1)}*\\n${items}`;\n  }).join('\\n\\n');\n\nmessages.push({ json: { text: `🛒 *Grocery List*\\n\\n${groceryLines}`, chat_id: $env.TELEGRAM_CHAT_ID } });\n\nreturn messages;"
      },
